# WalletIQ X Configuration Options
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=some_very_long_secret_key_here
SESSION_COOKIE_SECURE=true  # Set to true for HTTPS secure cookie handling in production

# Database Configuration
# Unified Database URL Connection String (Preferred for modern cloud platforms)
# e.g., mysql+pymysql://user:password@host:port/database
# If this is set, individual MYSQL_* variables below are ignored.
# DATABASE_URL=mysql://root:your_mysql_password_here@localhost:3306/walletiqdb

# Individual Database Parameters (Fallback option)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=walletiqdb

# Database Connection SSL Support (e.g. AWS RDS or DigitalOcean managed MySQL CA path)
# MYSQL_SSL_CA=/path/to/ca-cert.pem

# Gunicorn WSGI Server Log Configuration
# Defaults to stdout/stderr ("-") for cloud/Docker logs aggregation
# GUNICORN_ACCESSLOG=-
# GUNICORN_ERRORLOG=-

# Gemini AI Credentials
GEMINI_API_KEY=AIzaSy...
